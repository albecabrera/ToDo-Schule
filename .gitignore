# ── Secrets — NUNCA commitear ───────────────────────────────────────────────
backend/.env
.env
backend/storage/vapid.json

# ── Base de datos (live) + WAL ──────────────────────────────────────────────
backend/database.sqlite
backend/database.sqlite-wal
backend/database.sqlite-shm

# ── Estado en runtime (preservar el directorio vía .gitkeep) ────────────────
storage/backups/
backend/storage/*
!backend/storage/.gitkeep

# ── Uploads de usuarios (no versionar contenido subido) ─────────────────────
backend/public/avatars/*
!backend/public/avatars/.gitkeep
backend/public/chat-files/*
!backend/public/chat-files/.gitkeep
backend/uploads/*
!backend/uploads/.gitkeep

# ── Sistema / tooling ───────────────────────────────────────────────────────
node_modules/
.DS_Store
*.log
